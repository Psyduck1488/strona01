<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Symulacja Sił Zbrojnych</title>
    
    <style>
        /* TUTAJ TRAFIA TWÓJ KOD CSS */
     

        html, body {
            margin: 0;
            min-height: 100%;
            min-width: 100%;
            padding: 0;
            background-color: #f0f0f0; /* dodałem tło, żeby widzieć planszę */
        }

        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100vw;
            min-height: 100vh;
        }

        * {
            box-sizing: border-box;
        }

        /* Kontener główny (Board) */
        .board-ba7fefdebbb0 {
            position: relative;
            width: 1920px;
            height: 1080px;
            background: #FFFFFF;
            box-shadow: 0 0 20px rgba(0,0,0,0.2);
            overflow: hidden;
            z-index: 0;
            margin-top: 20px;
        }

        /* Stylizacja tekstu */
        .text-node { 
            background-clip: text !important; 
            -webkit-background-clip: text !important; 
        }

        .root-0 {
            display: flex;
            white-space: break-spaces;
            align-items: flex-start;
        }

        /* Pozycjonowanie elementów (Twoje klasy) */
        .artyleria-ba864168a18e {
            position: absolute;
            left: 50px; /* skorygowałem wartości, by były widoczne */
            top: 650px;
            width: 178px;
            height: 50px;
            font-size: 48px;
            font-family: "sourcesanspro";
        }

        .artyleria-ba8650da3883 {
            position: absolute;
            left: 1600px;
            top: 650px;
            width: 173px;
            height: 55px;
            font-size: 48px;
            font-family: "sourcesanspro";
        }

        .rectangle-ba873a408d60 {
            position: absolute;
            left: 1800px;
            top: 1000px;
            width: 98px;
            height: 51px;
            background: #ae1212;
        }

        /* Przykładowy styl dla listy wyposażenia */
        .a-k-m-a-k-s74-ba77e73ce824 {
            position: absolute;
            left: 1430px;
            top: 100px;
            font-family: "sourcesanspro";
            line-height: 1.5;
        }
        
        p { margin: 0; }
    </style>
</head>
<body>

    <div class="frame board-ba7fefdebbb0">
        
        <div class="shape rect rectangle-ba873a408d60"></div>

        <div class="shape text artyleria-ba864168a18e">
            <div class="root rich-text root-0">
                <p>artyleria</p>
            </div>
        </div>

        <div class="shape text artyleria-ba8650da3883">
            <div class="root rich-text root-0">
                <p>artyleria</p>
            </div>
        </div>

        <div class="shape text a-k-m-a-k-s74-ba77e73ce824">
            <div class="root rich-text root-0">
                <div class="paragraph-set">
                    <p><strong>Wyposażenie ZSRR:</strong></p>
                    <p>AKM</p>
                    <p>AKS-74U</p>
                    <p>PK machine gun</p>
                    <p>RPG-7</p>
                    <p>Makarov pistol</p>
                    <p>SSh-68 helmet</p>
                </div>
            </div>
        </div>

    </div>

</body>
</html>