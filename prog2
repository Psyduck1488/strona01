<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Test Widoku</title>
    <style>
        /* RESET I PODSTAWOWE USTAWIENIA */
        body {
            margin: 0;
            background-color: #2c3e50; /* Ciemne tło, żeby biała plansza była widoczna */
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        /* TWOJA PLANSZA (BOARD) */
        .board-ba7fefdebbb0 {
            position: relative;
            width: 1920px;  /* To jest bardzo szerokie! */
            height: 1080px;
            background: #ffffff;
            overflow: visible; /* Zmienione na visible, żeby widzieć co wystaje */
            border: 5px solid #e74c3c; /* CZERWONA RAMKA PLANSZY */
        }

        /* STYL DLA TEKSTU */
        .text-node-html {
            font-family: Arial, sans-serif;
            color: black;
            border: 1px dashed blue; /* NIEBIESKA RAMKA WOKÓŁ TEKSTU */
        }

        /* TWOJE KONKRETNE ELEMENTY (Przykładowe pozycje z Twojego kodu) */
        .artyleria-ba864168a18e {
            position: absolute;
            left: 100px; 
            top: 200px; /* Zmniejszyłem top, żeby było widać na górze */
            font-size: 48px;
        }

        .artyleria-ba8650da3883 {
            position: absolute;
            left: 1400px;
            top: 200px;
            font-size: 48px;
        }

        /* PROSTOKĄT - Jeśli nie dasz mu tła i rozmiaru, będzie niewidoczny! */
        .rectangle-ba873a408d60 {
            position: absolute;
            left: 500px;
            top: 400px;
            width: 200px;
            height: 100px;
            background: #ae1212; /* Czerwony kolor */
        }

        .ludzie-ba85b698e2b0 {
            position: absolute;
            left: 100px;
            top: 100px;
            font-size: 32px;
        }
    </style>
</head>
<body>

    <div class="frame board-ba7fefdebbb0">
        
        <div class="shape text ludzie-ba85b698e2b0">
            <div class="text-node-html">ludzie</div>
        </div>

        <div class="shape text artyleria-ba864168a18e">
            <div class="text-node-html">artyleria (lewa)</div>
        </div>

        <div class="shape text artyleria-ba8650da3883">
            <div class="text-node-html">artyleria (prawa)</div>
        </div>

        <div class="shape rect rectangle-ba873a408d60"></div>

    </div>

</body>
</html>